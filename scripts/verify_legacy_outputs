#!/bin/zsh
#
# Regenerate run1 into a temporary output root and compare it to frozen
# legacy-output fixtures from the pre-outputs/ layout.

set -euo pipefail

script_dir=${0:A:h}
repo_dir=${script_dir:h}
baseline_root=${BASELINE_ROOT:-$repo_dir/tests/fixtures/legacy_outputs}
input_root=${INPUT_ROOT:-/Users/jdsimon/mermaid/cfneic/inputs}
out_root=${VERIFY_OUT:-}

if [[ -z "$out_root" ]]; then
  out_root=$(mktemp -d /private/tmp/cfneic-verify-legacy-outputs.XXXXXX)
fi

baseline_root=${baseline_root:A}
input_root=${input_root:A}
out_root=${out_root:A}
run_dir=$out_root/outputs
tomocat=$input_root/tomocat.txt
verify_tomocat=$tomocat

for required in "$baseline_root" "$input_root"; do
  if [[ ! -e "$required" ]]; then
    print -u2 -- "ERROR: Required path does not exist: $required"
    exit 1
  fi
done

if [[ ! -e "$tomocat" ]]; then
  print -u2 -- "ERROR: Required path does not exist: $tomocat"
  exit 1
fi

tomocat_header_lines=0
while IFS= read -r line; do
  if [[ "$line" == \#* ]]; then
    tomocat_header_lines=$((tomocat_header_lines + 1))
  else
    break
  fi
done < "$tomocat"

if [[ $tomocat_header_lines -lt 2 ]]; then
  verify_tomocat=$out_root/tomocat.legacy-fixture.txt
  awk -v n=$((2 - tomocat_header_lines)) '
    /^#/ { print; next }
    skipped < n { print "#" $0; skipped++; next }
    { print }
  ' "$tomocat" > "$verify_tomocat"
fi

print "Verification output root: $out_root"
"$repo_dir/run_cfneic" \
  --input-root "$input_root" \
  --tomocat "$verify_tomocat" \
  --output-dir "$out_root"

rc=0
ok_checks=0
failed_checks=0

check_same() {
  local generated=$1
  local baseline=$2
  local label=$3
  if cmp -s "$generated" "$baseline"; then
    ok_checks=$((ok_checks + 1))
  else
    print -u2 -- "ERROR: MISMATCH $label"
    failed_checks=$((failed_checks + 1))
    rc=1
  fi
}

check_count() {
  local actual=$1
  local expected=$2
  local label=$3
  if [[ "$actual" == "$expected" ]]; then
    ok_checks=$((ok_checks + 1))
  else
    print -u2 -- "ERROR: MISMATCH $label: actual=$actual expected=$expected"
    failed_checks=$((failed_checks + 1))
    rc=1
  fi
}

check_neic_first_five_same() {
  local generated=$1
  local baseline=$2
  local label=$3
  local generated_first_five=$out_root/${label}.generated.first-five
  local baseline_first_five=$out_root/${label}.baseline.first-five
  awk '{print $1,$2,$3,$4,$5}' "$generated" > "$generated_first_five"
  awk '{print $1,$2,$3,$4,$5}' "$baseline" > "$baseline_first_five"
  check_same "$generated_first_five" "$baseline_first_five" "$label first five fields"
}

check_origin_sidecar() {
  local parent=$1
  local sidecar=$2
  local label=$3
  local parent_rows sidecar_rows bad_catalogs

  if [[ ! -s "$sidecar" ]]; then
    print -u2 -- "ERROR: MISSING generated $label"
    failed_checks=$((failed_checks + 1))
    rc=1
    return
  fi

  if ! sed -n '1,4p' "$sidecar" | cmp -s - "$repo_dir/tests/fixtures/origin_header.txt"; then
    print -u2 -- "ERROR: MISMATCH $label header"
    failed_checks=$((failed_checks + 1))
    rc=1
  else
    ok_checks=$((ok_checks + 1))
  fi

  parent_rows=$(awk 'NR > 1 {n++} END {print n + 0}' "$parent")
  sidecar_rows=$(awk '$1 !~ /^#/ && NF {n++} END {print n + 0}' "$sidecar")
  check_count "$sidecar_rows" "$parent_rows" "$label data row count"

  bad_catalogs=$(awk '$1 !~ /^#/ && NF && $1 != "ISC" && $1 != "NEIC" {n++} END {print n + 0}' "$sidecar")
  check_count "$bad_catalogs" "0" "$label catalog values"
}

check_same "$run_dir/out.cfneic_trig" \
  "$baseline_root/out.cfneic_trig_run1" "out.cfneic_trig"
check_same "$run_dir/out.cfneic_int" \
  "$baseline_root/out.cfneic_int_run1" "out.cfneic_int"
check_origin_sidecar "$run_dir/out.cfneic_trig" \
  "$run_dir/out.cfneic_trig.origin" "out.cfneic_trig.origin"
check_origin_sidecar "$run_dir/out.cfneic_int" \
  "$run_dir/out.cfneic_int.origin" "out.cfneic_int.origin"
check_same "$run_dir/hypos" "$baseline_root/hypos_run1" "hypos"
check_same "$run_dir/missed_events" \
  "$baseline_root/missed_events_run1" "missed_events"
check_same "$run_dir/log.cfneic" "$baseline_root/log.cfneic_run1" "log.cfneic"
check_neic_first_five_same "$run_dir/neic.txt" "$baseline_root/neic.txt" "neic.txt"
if [[ -e "$run_dir/dumgps" ]]; then
  print -u2 -- "ERROR: EXTRA generated dumgps"
  failed_checks=$((failed_checks + 1))
  rc=1
else
  ok_checks=$((ok_checks + 1))
fi

active_generated=($run_dir/GPS.*(N:t))
active_baseline=($baseline_root/GPS.*(N:t))
check_count "${#active_generated}" "${#active_baseline}" "active GPS file count"
for file in $active_baseline; do
  if [[ ! -e "$run_dir/$file" ]]; then
    print -u2 -- "ERROR: MISSING generated $file"
    failed_checks=$((failed_checks + 1))
    rc=1
  else
    check_same "$run_dir/$file" "$baseline_root/$file" "$file"
  fi
done
for file in $active_generated; do
  if [[ ! -e "$baseline_root/$file" ]]; then
    print -u2 -- "ERROR: EXTRA generated $file"
    failed_checks=$((failed_checks + 1))
    rc=1
  fi
done

empty_generated=($run_dir/empty_gps/GPS.*(N:t))
empty_baseline=($baseline_root/empty_gps/GPS.*(N:t))
check_count "${#empty_generated}" "${#empty_baseline}" "empty GPS file count"
for file in $empty_baseline; do
  if [[ ! -e "$run_dir/empty_gps/$file" ]]; then
    print -u2 -- "ERROR: MISSING generated empty_gps/$file"
    failed_checks=$((failed_checks + 1))
    rc=1
  else
    check_same "$run_dir/empty_gps/$file" "$baseline_root/empty_gps/$file" \
      "empty_gps/$file"
  fi
done
for file in $empty_generated; do
  if [[ ! -e "$baseline_root/empty_gps/$file" ]]; then
    print -u2 -- "ERROR: EXTRA generated empty_gps/$file"
    failed_checks=$((failed_checks + 1))
    rc=1
  fi
done

path_generated=($run_dir/path*.xy(N:t))
path_baseline=($baseline_root/path*.xy(N:t))
check_count "${#path_generated}" "${#path_baseline}" "path file count"
for file in $path_baseline; do
  if [[ ! -e "$run_dir/$file" ]]; then
    print -u2 -- "ERROR: MISSING generated $file"
    failed_checks=$((failed_checks + 1))
    rc=1
  else
    check_same "$run_dir/$file" "$baseline_root/$file" "$file"
  fi
done
for file in $path_generated; do
  if [[ ! -e "$baseline_root/$file" ]]; then
    print -u2 -- "ERROR: EXTRA generated $file"
    failed_checks=$((failed_checks + 1))
    rc=1
  fi
done

rdgps_generated=($run_dir/out.rdGPS*(N:t))
rdgps_baseline=($baseline_root/out.rdGPS*(N:t))
check_count "${#rdgps_generated}" "${#rdgps_baseline}" "out.rdGPS file count"
for file in $rdgps_baseline; do
  if [[ ! -e "$run_dir/$file" ]]; then
    print -u2 -- "ERROR: MISSING generated $file"
    failed_checks=$((failed_checks + 1))
    rc=1
  else
    tail -n +2 "$run_dir/$file" > "$out_root/$file.generated.body"
    tail -n +2 "$baseline_root/$file" > "$out_root/$file.baseline.body"
    check_same "$out_root/$file.generated.body" "$out_root/$file.baseline.body" \
      "$file body"
  fi
done
for file in $rdgps_generated; do
  if [[ ! -e "$baseline_root/$file" ]]; then
    print -u2 -- "ERROR: EXTRA generated $file"
    failed_checks=$((failed_checks + 1))
    rc=1
  fi
done

if [[ ! -e "$run_dir/rdgps_inputs" ]]; then
  ok_checks=$((ok_checks + 1))
else
  print -u2 -- "ERROR: MISMATCH rdgps_inputs exists"
  failed_checks=$((failed_checks + 1))
  rc=1
fi

if cmp -s "$run_dir/input_manifest.before" "$run_dir/input_manifest.after"; then
  ok_checks=$((ok_checks + 1))
else
  print -u2 -- "ERROR: MISMATCH input manifests before/after"
  failed_checks=$((failed_checks + 1))
  rc=1
fi

if [[ $rc -eq 0 ]]; then
  print "Verification complete: $ok_checks checks passed"
else
  print -u2 -- "ERROR: Verification checks passed: $ok_checks"
  print -u2 -- "ERROR: Verification checks failed: $failed_checks"
  print -u2 -- "ERROR: Verification failed: $run_dir"
fi

exit $rc
