#!/bin/zsh
#
# Legacy directory-mode helper for rdGPS.
# The supported workflow is run_cfneic with a flat --input-root.

script_dir=${0:A:h}
repo_dir=${script_dir:h}

# Adjust if more MERMAID serial prefixes come onboard
for d in 452*/; do
  dir=${d:t}
  last2=${dir[-2,-1]}
  "$repo_dir/build/rdGPS" "$dir" "$last2"
done
