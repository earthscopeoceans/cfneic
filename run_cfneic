#!/bin/zsh
#
# Run the legacy cfneic workflow from the source checkout without copying
# executables or data files into the run directory by hand.

set -euo pipefail

repo_dir=${0:A:h}
input_root=
output_dir=
tomocat=
neic=
ehb=
dry_run=false
output_suffix=run1
typeset -a geo_csvs
typeset -a geo_nrs

usage() {
  cat <<'EOF'
Usage:
  run_cfneic --output-dir DIR [--input-root DIR]
             [--tomocat FILE] [--neic FILE] [--ehb FILE]

Options:
  -i, --input-root DIR   Flat input directory containing *geo*.csv, neic.csv,
                         ehb.hdf, and tomocat.txt.
                         Default: output-dir/inputs
  -o, --output-dir DIR   Run root containing inputs/ and outputs/ subdirs.
                         Generated files go directly to output-dir/outputs.
      --tomocat FILE     tomocat input file. Default: input-root/tomocat.txt
      --neic FILE        NEIC CSV file. Default: input-root/neic.csv
      --ehb FILE         ISC-EHB HDF file. Default: input-root/ehb.hdf
      --dry-run          Show resolved paths and input preflight, then exit.
  -h, --help             Show this help.

The wrapper builds local executables with make if needed, runs rdGPS for each
flat *geo*.csv file under input-root, verifies input checksums did not change,
remakes output-dir/outputs, moves empty GPS files to empty_gps/, then runs cfneic.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--input-root)
      input_root=$2
      shift 2
      ;;
    -o|--output-dir)
      output_dir=$2
      shift 2
      ;;
    --tomocat)
      tomocat=$2
      shift 2
      ;;
    --neic)
      neic=$2
      shift 2
      ;;
    --ehb)
      ehb=$2
      shift 2
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      print -u2 "Unknown argument: $1"
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$output_dir" ]]; then
  print -u2 "--output-dir is required."
  usage >&2
  exit 2
fi

output_dir=${output_dir:A}
input_root=${input_root:-$output_dir/inputs}
input_root=${input_root:A}
outputs_root=$output_dir/outputs
run_dir=$outputs_root
tomocat=${tomocat:-$input_root/tomocat.txt}
neic=${neic:-$input_root/neic.csv}
ehb=${ehb:-$input_root/ehb.hdf}
tomocat=${tomocat:A}
neic=${neic:A}
ehb=${ehb:A}
error_log=$run_dir/errors.log

for required in "$input_root" "$tomocat" "$neic" "$ehb"; do
  if [[ ! -e "$required" ]]; then
    print -u2 "Required path does not exist: $required"
    exit 1
  fi
done

log_error() {
  print -r -- "$*" >> "$error_log"
}

write_input_manifest() {
  local manifest=$1
  (
    cd "$input_root"
    find . -type f -print | sort | while IFS= read -r file; do
      LC_ALL=C shasum -a 256 "$file"
    done
  ) > "$manifest"
}

write_neic_txt() {
  awk -F, '{print $1,$2,$3,$4,$5}' neic.csv > neic.txt
}

write_dumgps() {
  local gps
  : > dumgps
  for gps in GPS.*(N); do
    print -r -- "$gps" >> dumgps
  done
}

geo_station() {
  local csv=$1
  awk -F, '
    /^#/ { next }
    $1 == "MethodIdentifier" {
      for(i=1; i<=NF; i++) {
        if($i == "Station") station_col=i
      }
      next
    }
    station_col && $1 ~ /^Measurement:/ && $station_col != "" && $station_col != "nan" {
      print $station_col
      exit
    }
  ' "$csv"
}

station_to_nr() {
  local station=$1
  local nr=${station[2,-1]}
  while [[ ${#nr} -gt 2 && $nr == 0* ]]; do
    nr=${nr[2,-1]}
  done
  print -r -- "$nr"
}

filename_to_nr() {
  local filename=${1:t:r}
  local nr=
  if [[ "$filename" =~ '-[PN]-([[:alnum:]]+)' ]]; then
    nr=$match[1]
  fi
  while [[ ${#nr} -gt 2 && $nr == 0* ]]; do
    nr=${nr[2,-1]}
  done
  print -r -- "$nr"
}

neic_header_status() {
  local first
  if ! IFS= read -r first < "$neic"; then
    print "unreadable"
    return
  fi
  if [[ "$first" =~ '^[0-9]{4}-[0-9]{2}-[0-9]{2}T' ]]; then
    print "no header; legacy cfneic skips first NEIC row"
  else
    print "header/non-date first row; legacy cfneic skips it"
  fi
}

preflight_inputs() {
  local preflight_errors=0
  local geo_csv station nr source
  typeset -A seen_nrs

  geo_csvs=()
  geo_nrs=()

  print "Preflight:"
  print "  input root: $input_root"
  print "  output dir: $output_dir"
  print "  outputs dir: $run_dir"
  print "  cfneic output_suffix: $output_suffix (fixed legacy filename suffix)"
  print "  tomocat: $tomocat"
  print "  neic: $neic"
  print "  ehb: $ehb"
  print "  neic.csv: $(neic_header_status)"

  print "  outputs behavior: remove and recreate before generating products"

  for geo_csv in "$input_root"/*geo*.csv(N); do
    station=$(geo_station "$geo_csv")
    if [[ -n "$station" ]]; then
      nr=$(station_to_nr "$station")
      source="Station=$station"
    else
      nr=$(filename_to_nr "$geo_csv")
      source="filename fallback"
    fi
    if [[ -z "$nr" ]]; then
      print -u2 "Preflight: no station id for $geo_csv"
      preflight_errors=1
      continue
    fi
    if [[ -n "${seen_nrs[$nr]-}" ]]; then
      print -u2 "Preflight: duplicate station id '$nr' from $geo_csv"
      preflight_errors=1
      continue
    fi
    seen_nrs[$nr]=1
    geo_csvs+=("$geo_csv")
    geo_nrs+=("$nr")
    print "  GPS.$nr <= ${geo_csv:t} ($source)"
  done

  if [[ $#geo_csvs -eq 0 ]]; then
    print -u2 "No *geo*.csv files found under $input_root"
    preflight_errors=1
  else
    print "  GeoCSV files: $#geo_csvs"
  fi

  return $preflight_errors
}

preflight_inputs

if [[ "$dry_run" == true ]]; then
  print "Dry run complete."
  exit 0
fi

if [[ "$outputs_root" != */outputs || "$outputs_root" == "/outputs" ]]; then
  print -u2 "Refusing to remove suspicious outputs directory: $outputs_root"
  exit 1
fi
rm -rf "$outputs_root"
mkdir -p "$run_dir"
: > "$error_log"
export CFNEIC_ERROR_LOG=$error_log

make -C "$repo_dir"

input_manifest_before=$run_dir/input_manifest.before
input_manifest_after=$run_dir/input_manifest.after

check_input_manifest() {
  local exit_status=$?
  if [[ -f "$input_manifest_before" ]]; then
    if ! write_input_manifest "$input_manifest_after"; then
      exit_status=1
    elif ! cmp -s "$input_manifest_before" "$input_manifest_after"; then
      print -u2 "Input files changed during run: $input_root"
      print -u2 "Compare manifests:"
      print -u2 "  $input_manifest_before"
      print -u2 "  $input_manifest_after"
      exit_status=1
    fi
  fi
  exit $exit_status
}

write_input_manifest "$input_manifest_before"
trap check_input_manifest EXIT

(
  cd "$run_dir"

  cp "$neic" neic.csv
  cp "$ehb" ehb.hdf
  cp "$tomocat" tomocat.txt
  write_neic_txt

  nfloat=0
  for (( idx=1; idx<=${#geo_csvs}; idx++ )); do
    geo_csv=${geo_csvs[$idx]}
    nr=${geo_nrs[$idx]}
    nfloat=$((nfloat + 1))
    "$repo_dir/build/rdGPS" "$geo_csv" "$nr"
    if [[ ! -e "GPS.$nr" ]]; then
      log_error "rdGPS: no GPS.$nr created for $geo_csv"
      continue
    fi
  done

  if [[ $nfloat -eq 0 ]]; then
    print -u2 "No *geo*.csv files found under $input_root"
    exit 1
  fi

  mkdir -p empty_gps
  for gps in GPS.*(N); do
    ndata=$(awk 'NR > 1 && NF {n++} END {print n + 0}' "$gps")
    if [[ "$ndata" -eq 0 ]]; then
      log_error "rdGPS: moving header-only $gps to empty_gps/"
      mv "$gps" empty_gps/
    fi
  done

  gps_files=(GPS.*(N))
  if [[ $#gps_files -eq 0 ]]; then
    print -u2 "No non-empty GPS files remain after rdGPS processing."
    exit 1
  fi
  write_dumgps

  "$repo_dir/build/cfneic" tomocat.txt "$output_suffix"

  for expected in \
    "out.cfneic_trig_$output_suffix" \
    "out.cfneic_int_$output_suffix" \
    "hypos_$output_suffix" \
    "missed_events_$output_suffix" \
    "log.cfneic_$output_suffix"; do
    if [[ ! -s "$expected" ]]; then
      print -u2 "cfneic did not create expected non-empty output: $expected"
      exit 1
    fi
  done
)

print "Run complete: $run_dir"
