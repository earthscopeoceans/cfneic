#!/bin/zsh
#
# Run the legacy cfneic workflow from the source checkout without copying
# executables or data files into the run directory by hand.

set -euo pipefail

repo_dir=${0:A:h}
input_root=
output_dir=
ident=
tomocat=
neic=
ehb=

usage() {
  cat <<'EOF'
Usage:
  run_cfneic --output-dir DIR --ident IDENT [--input-root DIR]
             [--tomocat FILE] [--neic FILE] [--ehb FILE]

Options:
  -i, --input-root DIR   Flat input directory containing *geo*.csv, neic.csv,
                         ehb.hdf, and tomocat.txt.
                         Default: output-dir/inputs
  -o, --output-dir DIR   Run root containing inputs/ and outputs/ subdirs.
                         Generated files go to output-dir/outputs/IDENT.
  -n, --ident IDENT      cfneic run identifier, e.g. run1.
      --tomocat FILE     tomocat input file. Default: input-root/tomocat.txt
      --neic FILE        NEIC CSV file. Default: input-root/neic.csv
      --ehb FILE         ISC-EHB HDF file. Default: input-root/ehb.hdf
  -h, --help             Show this help.

The wrapper builds local executables with make if needed, runs rdGPS for each
flat *geo*.csv file under input-root, verifies input checksums did not change,
moves empty GPS files to empty_gps/, then runs cfneic from output-dir/outputs/IDENT.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--input-root)
      input_root=$2
      shift 2
      ;;
    -o|--output-dir)
      output_dir=$2
      shift 2
      ;;
    -n|--ident)
      ident=$2
      shift 2
      ;;
    --tomocat)
      tomocat=$2
      shift 2
      ;;
    --neic)
      neic=$2
      shift 2
      ;;
    --ehb)
      ehb=$2
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      print -u2 "Unknown argument: $1"
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$output_dir" || -z "$ident" ]]; then
  print -u2 "Both --output-dir and --ident are required."
  usage >&2
  exit 2
fi

output_dir=${output_dir:A}
input_root=${input_root:-$output_dir/inputs}
input_root=${input_root:A}
outputs_root=$output_dir/outputs
run_dir=$outputs_root/$ident
tomocat=${tomocat:-$input_root/tomocat.txt}
neic=${neic:-$input_root/neic.csv}
ehb=${ehb:-$input_root/ehb.hdf}
tomocat=${tomocat:A}
neic=${neic:A}
ehb=${ehb:A}

for required in "$input_root" "$tomocat" "$neic" "$ehb"; do
  if [[ ! -e "$required" ]]; then
    print -u2 "Required path does not exist: $required"
    exit 1
  fi
done

mkdir -p "$outputs_root"
mkdir -p "$run_dir"
if [[ -n "$(find "$run_dir" -mindepth 1 -maxdepth 1 -print -quit)" ]]; then
  print -u2 "Run output directory must be empty: $run_dir"
  exit 1
fi
error_log=$run_dir/errors.log
: > "$error_log"
export CFNEIC_ERROR_LOG=$error_log

log_error() {
  print -r -- "$*" >> "$error_log"
}

write_input_manifest() {
  local manifest=$1
  (
    cd "$input_root"
    find . -type f -print | sort | while IFS= read -r file; do
      LC_ALL=C shasum -a 256 "$file"
    done
  ) > "$manifest"
}

geo_station() {
  local csv=$1
  awk -F, '
    /^#/ { next }
    $1 == "MethodIdentifier" {
      for(i=1; i<=NF; i++) {
        if($i == "Station") station_col=i
      }
      next
    }
    station_col && $1 ~ /^Measurement:/ && $station_col != "" && $station_col != "nan" {
      print $station_col
      exit
    }
  ' "$csv"
}

station_to_nr() {
  local station=$1
  local nr=${station[2,-1]}
  while [[ ${#nr} -gt 2 && $nr == 0* ]]; do
    nr=${nr[2,-1]}
  done
  print -r -- "$nr"
}

filename_to_nr() {
  local filename=${1:t:r}
  local nr=
  if [[ "$filename" =~ '-[PN]-([[:alnum:]]+)' ]]; then
    nr=$match[1]
  fi
  while [[ ${#nr} -gt 2 && $nr == 0* ]]; do
    nr=${nr[2,-1]}
  done
  print -r -- "$nr"
}

make -C "$repo_dir"

input_manifest_before=$run_dir/input_manifest.before
input_manifest_after=$run_dir/input_manifest.after

check_input_manifest() {
  local exit_status=$?
  if [[ -f "$input_manifest_before" ]]; then
    if ! write_input_manifest "$input_manifest_after"; then
      exit_status=1
    elif ! cmp -s "$input_manifest_before" "$input_manifest_after"; then
      print -u2 "Input files changed during run: $input_root"
      print -u2 "Compare manifests:"
      print -u2 "  $input_manifest_before"
      print -u2 "  $input_manifest_after"
      exit_status=1
    fi
  fi
  exit $exit_status
}

write_input_manifest "$input_manifest_before"
trap check_input_manifest EXIT

(
  cd "$run_dir"

  cp "$neic" neic.csv
  cp "$ehb" ehb.hdf
  cp "$tomocat" tomocat.txt

  typeset -A seen_nrs

  nfloat=0
  for geo_csv in "$input_root"/*geo*.csv(N); do
    station=$(geo_station "$geo_csv")
    if [[ -n "$station" ]]; then
      nr=$(station_to_nr "$station")
    else
      nr=$(filename_to_nr "$geo_csv")
      if [[ -z "$nr" ]]; then
        log_error "rdGPS: no station found and no station id in filename $geo_csv"
        continue
      fi
    fi
    if [[ -z "$nr" || -n "${seen_nrs[$nr]-}" ]]; then
      log_error "rdGPS: duplicate or invalid station id '$nr' from $geo_csv"
      continue
    fi
    seen_nrs[$nr]=1
    nfloat=$((nfloat + 1))
    "$repo_dir/build/rdGPS" "$geo_csv" "$nr"
    if [[ ! -e "GPS.$nr" ]]; then
      log_error "rdGPS: no GPS.$nr created for $geo_csv"
      continue
    fi
  done

  if [[ $nfloat -eq 0 ]]; then
    print -u2 "No *geo*.csv files found under $input_root"
    exit 1
  fi

  mkdir -p empty_gps
  for gps in GPS.*(N); do
    ndata=$(awk 'NR > 1 && NF {n++} END {print n + 0}' "$gps")
    if [[ "$ndata" -eq 0 ]]; then
      log_error "rdGPS: moving header-only $gps to empty_gps/"
      mv "$gps" empty_gps/
    fi
  done

  gps_files=(GPS.*(N))
  if [[ $#gps_files -eq 0 ]]; then
    print -u2 "No non-empty GPS files remain after rdGPS processing."
    exit 1
  fi

  "$repo_dir/build/cfneic" tomocat.txt "$ident"

  for expected in \
    "out.cfneic_trig_$ident" \
    "out.cfneic_int_$ident" \
    "hypos_$ident" \
    "missed_events_$ident" \
    "log.cfneic_$ident"; do
    if [[ ! -s "$expected" ]]; then
      print -u2 "cfneic did not create expected non-empty output: $expected"
      exit 1
    fi
  done
)

print "Run complete: $run_dir"
